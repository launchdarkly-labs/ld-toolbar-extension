{
  "name": "@launchdarkly/toolbar-extension-bridge",
  "version": "0.0.1",
  "description": "LaunchDarkly SDK plugin that bridges flag overrides between a host app and the LD Dev Toolbar Chrome extension. In-memory only; no localStorage.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "launchdarkly-js-client-sdk": ">=3.6.0 <4.0.0"
  },
  "devDependencies": {
    "launchdarkly-js-client-sdk": "^3.9.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
